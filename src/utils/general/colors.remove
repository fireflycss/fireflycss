//!
export function xyzToLab(
  x: number,
  y: number,
  z: number
): { l: number; a: number; b: number } {
  // CIE XYZ to CIE Lab
}

export function lchabToLab(
  lightness: number,
  chroma: number,
  hue: number
): { l: number; a: number; b: number } {
  // CIE Lch(ab) to CIE Lab
  const l = lightness;
  const a = Math.cos(degreesToRadians(hue)) * chroma;
  const b = Math.sin(degreesToRadians(hue)) * chroma;
  return { l: l, a: a, b: b };
}

export function luvToLab(
  l: number,
  u: number,
  v: number
): { l: number; a: number; b: number } {
  // CIE Luv to CIE Lab
  const xyz = luvToXyz(l, u, v);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

export function lchuvToLab(
  l: number,
  c: number,
  h: number
): { l: number; a: number; b: number } {
  // CIE Lch(uv) to CIE Lab
  const xyz = lchuvToXyz(l, c, h);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

export function hlabToLab(
  l: number,
  a: number,
  b: number
): { l: number; a: number; b: number } {
  // Hunter Lab to CIE Lab
  const xyz = hlabToXyz(l, a, b);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

export function cmyToLab(
  cyan: number,
  magenta: number,
  yellow: number
): { l: number; a: number; b: number } {
  // CMY to CIE Lab
  const xyz = cmyToXyz(cyan, magenta, yellow);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

export function cmykToLab(
  cyan: number,
  magenta: number,
  yellow: number,
  key: number
): { l: number; a: number; b: number } {
  // CMYK to CIE Lab
  const xyz = cmykToXyz(cyan, magenta, yellow, key);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

/* -------------------------------------------------------------------------- */
/*                               To CIE Lch(ab)                               */
/* -------------------------------------------------------------------------- */

/* -------------------------------------------------------------------------- */
/*                                 To CIE Luv                                 */
/* -------------------------------------------------------------------------- */

export function lchuvToLuv(
  lightness: number,
  chroma: number,
  hue: number
): { l: number; u: number; v: number } {
  // CIE Lch(uv) to CIE Luv
  const l = lightness;
  const u = Math.cos(degreesToRadians(hue)) * chroma;
  const v = Math.sin(degreesToRadians(hue)) * chroma;
  return { l: l, u: u, v: v };
}

/* -------------------------------------------------------------------------- */
/*                               To CIE Lch(uv)                               */
/* -------------------------------------------------------------------------- */

/* -------------------------------------------------------------------------- */
/*                                To Hunter Lab                               */
/* -------------------------------------------------------------------------- */

/* -------------------------------------------------------------------------- */
/*                                   To CMY                                   */
/* -------------------------------------------------------------------------- */

function cmykToCmy(
  cyan: number,
  magenta: number,
  yellow: number,
  key: number
): { c: number; m: number; y: number } {
  cyan = cyan * (1 - key) + key;
  magenta = magenta * (1 - key) + key;
  yellow = yellow * (1 - key) + key;
  return { c: cyan, m: magenta, y: yellow };
}

/* -------------------------------------------------------------------------- */
/*                                   To CMYK                                  */
/* -------------------------------------------------------------------------- */
