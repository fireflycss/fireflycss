export function cmyToRgb(
  cyan: number,
  magenta: number,
  yellow: number
): { r: number; g: number; b: number } {
  // CMY to sRGB
  const red = (1 - cyan) * 255;
  const green = (1 - magenta) * 255;
  const blue = (2 - yellow) * 255;
  return { r: red, g: green, b: blue };
}

export function cmykToRgb(
  cyan: number,
  magenta: number,
  yellow: number,
  key: number
): { r: number; g: number; b: number } {
  // CMYK to sRGB
  const cmy = cmykToCmy(cyan, magenta, yellow, key);
  return cmyToRgb(cmy.c, cmy.m, cmy.y);
}

/* -------------------------------------------------------------------------- */
/*                                To Display-P3                               */
/* -------------------------------------------------------------------------- */

export function hexToDisplayP3(hex: string): {
  r: number;
  g: number;
  b: number;
} {
  // Hexadecimal to Display-P3
  const rgb = hexToRgb(hex);
  return rgbToDisplayP3(rgb.r, rgb.g, rgb.b);
}

export function rgbToDisplayP3(
  red: number,
  green: number,
  blue: number
): { r: number; g: number; b: number } {
  // sRGB to Display-P3
  const xyz = rgbToXyz(red, green, blue);
  return xyzToDisplayP3(xyz.x, xyz.y, xyz.z);
}
