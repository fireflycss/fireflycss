export function labToXyz(
  l: number,
  a: number,
  b: number
): { x: number; y: number; z: number } {
  // CIE Lab to CIE XYZ
  let y = (l + 16) / 116;
  let x = a / 500 + y;
  let z = y - b / 200;
  x = Math.pow(x, 3) > 0.008_856 ? Math.pow(x, 3) : (x - 16 / 116) / 7.787;
  y = Math.pow(y, 3) > 0.008_856 ? Math.pow(y, 3) : (y - 16 / 116) / 7.787;
  z = Math.pow(z, 3) > 0.008_856 ? Math.pow(z, 3) : (z - 16 / 116) / 7.787;

  const referenceXyz = getReferenceXyz();
  x = x * referenceXyz.x;
  y = y * referenceXyz.y;
  z = z * referenceXyz.z;

  return { x: x, y: y, z: z };
}

export function lchabToXyz(
  lightness: number,
  chroma: number,
  hue: number
): { x: number; y: number; z: number } {
  // CIE Lch(ab) to CIE XYZ
  const lab = lchabToLab(lightness, chroma, hue);
  return labToXyz(lab.l, lab.a, lab.b);
}
