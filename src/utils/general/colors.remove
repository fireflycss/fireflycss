/* -------------------------------------------------------------------------- */
/*                                   To HWB                                   */
/* -------------------------------------------------------------------------- */
// Returns {h:hue,w:whiteness,b:blackness}
export function hexToHwb(hex: string): { h: number; w: number; b: number } {
  // Hexadecimal to HWB
  const rgb = hexToRgb(hex);
  return rgbToHwb(rgb.r, rgb.g, rgb.b);
}

export function rgbToHwb(
  red: number,
  green: number,
  blue: number
): { h: number; w: number; b: number } {
  // sRGB to HWB
  red = red / 255;
  green = green / 255;
  blue = blue / 255;
  const max = Math.max(red, green, blue);
  const min = Math.min(red, green, blue);
  const chroma = max - min;
  let hue;
  if (chroma == 0) {
    hue = 0;
  } else if (red == max) {
    hue = (((green - blue) / chroma) % 6) * 360;
  } else if (green == max) {
    hue = (((blue - red) / chroma + 2) % 6) * 360;
  } else {
    hue = (((red - green) / chroma + 4) % 6) * 360;
  }
  const whiteness = min;
  const blackness = 1 - max;
  return { h: hue, w: whiteness, b: blackness };
}
//!
