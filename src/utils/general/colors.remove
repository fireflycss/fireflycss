export function xyzToDisplayP3(
  x: number,
  y: number,
  z: number
): {
  r: number;
  g: number;
  b: number;
} {
  // CIE XYZ to Display-P3
  // convert inputs to 0-1 range
  x /= 100;
  y /= 100;
  z /= 100;
  // Matrix multiplication
  let red = x * 2.493_496_9 + y * -0.931_383_6 + z * -0.402_710_8;
  let green = x * -0.829_489 + y * 1.762_664_1 + z * 0.023_624_7;
  let blue = x * 0.035_845_8 + y * -0.076_172_4 + z * 0.956_884_5;
  // Transform linear values to Display-P3 (gamma correction)
  red =
    red > 0.003_130_8 ? 1.055 * Math.pow(red, 1 / 2.4) - 0.055 : 12.92 * red;
  green =
    green > 0.003_130_8
      ? 1.055 * Math.pow(green, 1 / 2.4) - 0.055
      : 12.92 * green;
  blue =
    blue > 0.003_130_8 ? 1.055 * Math.pow(blue, 1 / 2.4) - 0.055 : 12.92 * blue;

  return { r: red, g: green, b: blue };
}

export function labToDisplayP3(
  l: number,
  a: number,
  b: number
): {
  r: number;
  g: number;
  b: number;
} {
  // CIE Lab to Display-P3
  const xyz = labToXyz(l, a, b);
  return xyzToDisplayP3(xyz.x, xyz.y, xyz.z);
}

export function lchabToDisplayP3(
  lightness: number,
  chroma: number,
  hue: number
): {
  r: number;
  g: number;
  b: number;
} {
  // CIE Lch(ab) to Display-P3
  const xyz = lchabToXyz(lightness, chroma, hue);
  return xyzToDisplayP3(xyz.x, xyz.y, xyz.z);
}

export function luvToDisplayP3(
  l: number,
  u: number,
  v: number
): {
  r: number;
  g: number;
  b: number;
} {
  // CIE Luv to Display-P3
  const xyz = labToXyz(l, u, v);
  return xyzToDisplayP3(xyz.x, xyz.y, xyz.z);
}

export function lchuvToDisplayP3(
  lightness: number,
  chroma: number,
