/*
 * Information:
 * All functions assume valid inputs
 * Default XYZ reference is D65, 2 degrees
 * Hex input will not consider opacity
 * sRGB Values 0-255
 */

/* -------------------------------------------------------------------------- */
/*                      General Functions For Conversion                      */
/* -------------------------------------------------------------------------- */

function getReferenceXyz(): { x: number; y: number; z: number } {
  // D65(Daylight, sRGB, Adobe-RGB)
  // 2 degrees
  const x = 95.047;
  const y = 100;
  const z = 108.883;
  return { x: x, y: y, z: z };
}

function degreesToRadians(degrees: number) {
  return degrees * (Math.PI / 180);
}

function rgbToXyzMatrix(
  xr: number,
  yr: number,
  xg: number,
  yg: number,
  xb: number,
  yb: number,
  xw: number,
  yw: number,
  zw: number
) {
  //Computes 3x3 matrix for RGB to XYZ
  const Xr = xr / yr;
  const Yr = 1;
  const Zr = (1 - xr - yr) / yr;
  const Xg = xg / yg;
  const Yg = 1;
  const Zg = (1 - xg - yg) / yg;
  const Xb = xb / yb;
  const Yb = 1;
  const Zb = (1 - xb - yb) / yb;
  const matrix = {
    a: Xr,
    b: Xg,
    c: Xb,
    d: Yr,
    e: Yg,
    f: Yb,
    g: Zr,
    h: Zg,
    i: Zb,
  };
  const invertedMatrix = invert3x3Matrix(matrix);
  // multiply by reference white
  const s = multiply3x3Matrix3x1(invertedMatrix, { a: xw, b: yw, c: zw });
  const Sr = s.a;
  const Sg = s.b;
  const Sb = s.c;
  const A = Sr * Xr;
  const B = Sg * Xg;
  const C = Sb * Xb;
  const D = Sr * Yr;
  const E = Sg * Yg;
  const F = Sb * Yb;
  const G = Sr * Zr;
  const H = Sg * Zg;
  const I = Sb * Zb;
  return { a: A, b: B, c: C, d: D, e: E, f: F, g: G, h: H, i: I };
}

function xyzToRgbMatrix(
  xr: number,
  yr: number,
  xg: number,
  yg: number,
  xb: number,
  yb: number,
  xw: number,
  yw: number,
  zw: number
) {
  // Computes 3x3 matrix for XYZ to RGB
  // Primaries: xr,yr,xg,yg,xb,yb
  // Reference white: xw,yw,zw
  const matrix = rgbToXyzMatrix(xr, yr, xg, yg, xb, yb, xw, yw, zw);
  return invert3x3Matrix(matrix);
}

function invert3x3Matrix(matrix: {
  a: number;
  b: number;
  c: number;
  d: number;
  e: number;
  f: number;
  g: number;
  h: number;
  i: number;
}) {
  // inverts a 3×3 matrix
  /* eslint-disable unicorn/prevent-abbreviations */
  const a = matrix.a;
  const b = matrix.b;
  const c = matrix.c;
  const d = matrix.d;
  const e = matrix.e;
  const f = matrix.f;
  const g = matrix.g;
  const h = matrix.h;
  const i = matrix.i;

  const determinant =
    a * (e * i - f * h) - b * (i * d - f * g) + c * (d * h - e * g);

  const A = (e * i - f * h) / determinant;
  const B = (f * g - d * i) / determinant;
  const C = (d * h - e * g) / determinant;
  const D = (c * h - b * i) / determinant;
  const E = (a * i - c * g) / determinant;
  const F = (b * g - a * h) / determinant;
  const G = (b * f - c * e) / determinant;
  const H = (c * d - a * f) / determinant;
  const I = (a * e - b * d) / determinant;

  return { a: A, b: B, c: C, d: D, e: E, f: F, g: G, h: H, i: I };
  /* eslint-enable unicorn/prevent-abbreviations */
}

function multiply3x3Matrix3x1(
  m1: {
    a: number;
    b: number;
    c: number;
    d: number;
    e: number;
    f: number;
    g: number;
    h: number;
    i: number;
  },
  m2: { a: number; b: number; c: number }
) {
  const A = m1.a * m2.a + m1.b * m2.a + m1.c * m2.a;
  const B = m1.d * m2.b + m1.e * m2.b + m1.f * m2.b;
  const C = m1.g * m2.c + m1.h * m2.c + m1.i * m2.c;
  return { a: A, b: B, c: C };
}

/* -------------------------------------------------------------------------- */
/*                                   To HEX                                   */
/* -------------------------------------------------------------------------- */
// Returns "#[a-f0-9]{3,4,6 or 8}"

export function rgbToHex(red: number, green: number, blue: number): string {
  // sRGB to Hexadecimal
  const rgb = (red << 16) | (green << 8) | Math.trunc(blue);
  return "#" + (0x1_00_00_00 + rgb).toString(16).slice(1);
}

export function displayP3ToHex(
  p3Red: number,
  p3Green: number,
  p3Blue: number
): string {
  // Display-P3 to Hexadecimal
  const rgb = displayP3ToRgb(p3Red, p3Green, p3Blue);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function hslToHex(
  hue: number,
  saturation: number,
  lightness: number
): string {
  // HSL to Hexadecimal
  lightness /= 100;
  const a = (saturation * Math.min(lightness, 1 - lightness)) / 100;
  const f = (n: number) => {
    const k = (n + hue / 30) % 12;
    const color = lightness - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
    return Math.round(255 * color)
      .toString(16)
      .padStart(2, "0"); // convert to Hex and prefix "0" if needed
  };
  return "#" + f(0) + f(8) + f(4);
}

export function hsvToHex(
  hue: number,
  saturation: number,
  value: number
): string {
  // HSV to Hexadecimal
  const rgb = hsvToRgb(hue, saturation, value);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function hsbToHex(
  hue: number,
  saturation: number,
  brightness: number
): string {
  // HSB to Hexadecimal
  const rgb = hsbToRgb(hue, saturation, brightness);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function hwbToHex(
  hue: number,
  whiteness: number,
  blackness: number
): string {
  // HWB to Hexadecimal

  const rgb = hwbToRgb(hue, whiteness, blackness);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function labToHex(l: number, a: number, b: number): string {
  // CIE Lab to Hexadecimal
  const rgb = labToRgb(l, a, b);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function lchabToHex(
  lightness: number,
  chroma: number,
  hue: number
): string {
  // CIE Lch(ab) to Hexadecimal
  const rgb = lchabToRgb(lightness, chroma, hue);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function luvToHex(l: number, u: number, v: number): string {
  // CIE Luv to Hexadecimal
  const rgb = luvToRgb(l, u, v);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function lchuvToHex(
  lightness: number,
  chroma: number,
  hue: number
): string {
  // CIE Lch(uv) to Hexadecimal
  const rgb = lchuvToRgb(lightness, chroma, hue);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function hlabToHex(l: number, a: number, b: number): string {
  // Hunter Lab to Hexadecimal
  const rgb = hlabToRgb(l, a, b);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function cmyToHex(
  cyan: number,
  magenta: number,
  yellow: number
): string {
  // CMY to Hexadecimal
  const rgb = cmyToRgb(cyan, magenta, yellow);
  return rgbToHex(rgb.r, rgb.g, rgb.b);
}

export function cmykToHex(
  cyan: number,
  magenta: number,
  yellow: number,
  key: number
): string {
  // CMYK to Hexadecimal
  const cmy = cmykToCmy(cyan, magenta, yellow, key);
  return cmyToHex(cmy.c, cmy.m, cmy.y);
}

/* -------------------------------------------------------------------------- */
/*                                   To sRGB                                  */
/* -------------------------------------------------------------------------- */
// Returns {r:red,g:green,b:blue,a?:alpha}

export function hexToRgb(hex: string): { r: number; g: number; b: number } {
  // Hexadecimal to sRGB
  hex = hex.replace("#", "");
  let red, green, blue;
  if (hex.length >= 6) {
    red = Number.parseInt(hex.slice(0, 2), 16);
    green = Number.parseInt(hex.slice(2, 4), 16);
    blue = Number.parseInt(hex.slice(4, 6), 16);
  } else if (hex.length >= 3) {
    red = Number.parseInt(hex.charAt(0) + hex.charAt(0), 16);
    green = Number.parseInt(hex.charAt(1) + hex.charAt(1), 16);
    blue = Number.parseInt(hex.charAt(2) + hex.charAt(2), 16);
  } else {
    red = 0;
    green = 0;
    blue = 0;
  }
  return { r: red, g: green, b: blue };
}
//?
export function hexToRgba(hex: string): {
  r: number;
  g: number;
  b: number;
  a: number | undefined;
} {
  // Hexadecimal to sRGB
  hex = hex.replace("#", "");
  let red, green, blue, alpha;
  if (hex.length == 6) {
    red = Number.parseInt(hex.slice(0, 2), 16);
    green = Number.parseInt(hex.slice(2, 4), 16);
    blue = Number.parseInt(hex.slice(4, 6), 16);
  } else if (hex.length == 8) {
    red = Number.parseInt(hex.slice(0, 2), 16);
    green = Number.parseInt(hex.slice(2, 4), 16);
    blue = Number.parseInt(hex.slice(4, 6), 16);
    alpha = Number.parseInt(hex.slice(6, 8), 16);
  } else if (hex.length == 3) {
    red = Number.parseInt(hex.charAt(0) + hex.charAt(0), 16);
    green = Number.parseInt(hex.charAt(1) + hex.charAt(1), 16);
    blue = Number.parseInt(hex.charAt(2) + hex.charAt(2), 16);
  } else if (hex.length == 4) {
    red = Number.parseInt(hex.charAt(0) + hex.charAt(0), 16);
    green = Number.parseInt(hex.charAt(1) + hex.charAt(1), 16);
    blue = Number.parseInt(hex.charAt(2) + hex.charAt(2), 16);
    alpha = Number.parseInt(hex.charAt(3) + hex.charAt(3), 16);
  } else {
    red = 0;
    green = 0;
    blue = 0;
    alpha = 0;
  }
  return { r: red, g: green, b: blue, a: alpha };
}

export function displayP3ToRgb(
  p3Red: number,
  p3Green: number,
  p3Blue: number
): { r: number; g: number; b: number } {
  // Display-P3 to sRGB
  const xyz = displayP3ToXyz(p3Red, p3Green, p3Blue);
  return xyzToRgb(xyz.x, xyz.y, xyz.z);
}

export function hslToRgb(
  hue: number,
  saturation: number,
  lightness: number
): { r: number; g: number; b: number } {
  // HSL to sRGB
  // Must be fractions of 1
  saturation /= 100;
  lightness /= 100;

  const c = (1 - Math.abs(2 * lightness - 1)) * saturation;
  const x = c * (1 - Math.abs(((hue / 60) % 2) - 1));
  const m = lightness - c / 2;
  let red = 0;
  let green = 0;
  let blue = 0;
  if (0 <= hue && hue < 60) {
    red = c;
    green = x;
    blue = 0;
  } else if (60 <= hue && hue < 120) {
    red = x;
    green = c;
    blue = 0;
  } else if (120 <= hue && hue < 180) {
    red = 0;
    green = c;
    blue = x;
  } else if (180 <= hue && hue < 240) {
    red = 0;
    green = x;
    blue = c;
  } else if (240 <= hue && hue < 300) {
    red = x;
    green = 0;
    blue = c;
  } else if (300 <= hue && hue < 360) {
    red = c;
    green = 0;
    blue = x;
  }
  red = Math.round((red + m) * 255);
  green = Math.round((green + m) * 255);
  blue = Math.round((blue + m) * 255);
  return { r: red, g: green, b: blue };
}

export function hsvToRgb(
  hue: number,
  saturation: number,
  value: number
): { r: number; g: number; b: number } {
  // HSV to sRGB
  //todo This code expects 0 <= h, s, v <= 1
  let red;
  let green;
  let blue;

  const index = Math.floor(hue * 6);
  const f = hue * 6 - index;
  const p = value * (1 - saturation);
  const q = value * (1 - f * saturation);
  const t = value * (1 - (1 - f) * saturation);
  switch (index % 6) {
    default:
    case 0:
      (red = value), (green = t), (blue = p);
      break;
    case 1:
      (red = q), (green = value), (blue = p);
      break;
    case 2:
      (red = p), (green = value), (blue = t);
      break;
    case 3:
      (red = p), (green = q), (blue = value);
      break;
    case 4:
      (red = t), (green = p), (blue = value);
      break;
    case 5:
      (red = value), (green = p), (blue = q);
      break;
  }
  red = Math.round(red * 255);
  green = Math.round(green * 255);
  blue = Math.round(blue * 255);
  return { r: red, g: green, b: blue };
}

export function hsbToRgb(
  hue: number,
  saturation: number,
  brightness: number
): { r: number; g: number; b: number } {
  let red;
  let green;
  let blue;

  const index = Math.floor(hue * 6);
  const f = hue * 6 - index;
  const p = brightness * (1 - saturation);
  const q = brightness * (1 - f * saturation);
  const t = brightness * (1 - (1 - f) * saturation);
  switch (index % 6) {
    default:
    case 0:
      (red = brightness), (green = t), (blue = p);
      break;
    case 1:
      (red = q), (green = brightness), (blue = p);
      break;
    case 2:
      (red = p), (green = brightness), (blue = t);
      break;
    case 3:
      (red = p), (green = q), (blue = brightness);
      break;
    case 4:
      (red = t), (green = p), (blue = brightness);
      break;
    case 5:
      (red = brightness), (green = p), (blue = q);
      break;
  }
  red = Math.round(red * 255);
  green = Math.round(green * 255);
  blue = Math.round(blue * 255);
  return { r: red, g: green, b: blue };
  // HSB to sRGB
}

export function hwbToRgb(
  hue: number,
  whiteness: number,
  blackness: number
): { r: number; g: number; b: number } {
  // HWB to sRGB
  hue /= 60;
  // Must be fractions of 1
  whiteness /= 100;
  blackness /= 100;
  const ratio = whiteness + blackness;
  let v = 1 - blackness;
  let n;
  let f;
  if (!hue) return { r: v, g: v, b: v };

  // whiteness + blackness can't be >1
  if (ratio > 1) {
    whiteness /= ratio;
    blackness /= ratio;
  }

  const index = Math.trunc(hue);
  f = hue - index;
  if (index & 1) f = 1 - f;
  n = whiteness + f * (v - whiteness);
  v = Math.round(v * 255);
  n = Math.round(n * 255);
  whiteness = Math.round(whiteness * 255);

  let red;
  let green;
  let blue;
  switch (index) {
    default:
    case 6:
    case 0:
      red = v;
      green = n;
      blue = whiteness;
      break;
    case 1:
      red = n;
      green = v;
      blue = whiteness;
      break;
    case 2:
      red = whiteness;
      green = v;
      blue = n;
      break;
    case 3:
      red = whiteness;
      green = n;
      blue = v;
      break;
    case 4:
      red = n;
      green = whiteness;
      blue = v;
      break;
    case 5:
      red = v;
      green = whiteness;
      blue = n;
      break;
  }
  return { r: red, g: green, b: blue };
}

export function xyzToRgb(
  x: number,
  y: number,
  z: number
): { r: number; g: number; b: number } {
  // CIE XYZ to sRGB
  // convert inputs to 0-1 range
  x /= 100;
  y /= 100;
  z /= 100;
  // Matrix multiplication
  let red = x * 3.2406 + y * -1.5372 + z * -0.4986;
  let green = x * -0.9689 + y * 1.8758 + z * 0.0415;
  let blue = x * 0.0557 + y * -0.204 + z * 1.057;
  // Transform linear values to sRGB (gamma correction)
  red =
    red > 0.003_130_8 ? 1.055 * Math.pow(red, 1 / 2.4) - 0.055 : 12.92 * red;
  green =
    green > 0.003_130_8
      ? 1.055 * Math.pow(green, 1 / 2.4) - 0.055
      : 12.92 * green;
  blue =
    blue > 0.003_130_8 ? 1.055 * Math.pow(blue, 1 / 2.4) - 0.055 : 12.92 * blue;
  // convert to 0-255 range
  red = red * 255;
  green = green * 255;
  blue = blue * 255;
  return { r: red, g: green, b: blue };
}

export function labToRgb(
  l: number,
  a: number,
  b: number
): { r: number; g: number; b: number } {
  // CIE Lab to sRGB
  const xyz = labToXyz(l, a, b);
  return xyzToRgb(xyz.x, xyz.y, xyz.z);
}

export function lchabToRgb(
  lightness: number,
  chroma: number,
  hue: number
): { r: number; g: number; b: number } {
  // CIE Lch(ab) to sRGB
  const lab = lchabToLab(lightness, chroma, hue);
  return labToRgb(lab.l, lab.a, lab.b);
}

export function luvToRgb(
  l: number,
  u: number,
  v: number
): { r: number; g: number; b: number } {
  // CIE Luv to sRGB
  const xyz = luvToXyz(l, u, v);
  return xyzToRgb(xyz.x, xyz.y, xyz.z);
}

export function lchuvToRgb(
  lightness: number,
  chroma: number,
  hue: number
): { r: number; g: number; b: number } {
  // CIE Lch(uv) to sRGB
  const lab = lchuvToLuv(lightness, chroma, hue);
  return luvToRgb(lab.l, lab.u, lab.v);
}
