/* -------------------------------------------------------------------------- */
/*                                 To CIE XYZ                                 */
/* -------------------------------------------------------------------------- */
// Returns {x:x,y:y,z:z}

export function hexToXyz(hex: string): { x: number; y: number; z: number } {
  // Hexadecimal to CIE XYZ
  const rgb = hexToRgb(hex);
  const xyz = rgbToXyz(rgb.r, rgb.g, rgb.b);
  return { x: xyz.x, y: xyz.y, z: xyz.z };
}

export function rgbToXyz(
  red: number,
  green: number,
  blue: number
): { x: number; y: number; z: number } {
  // sRGB to CIE XYZ
  // convert to range of 0-1
  red = red / 255;
  green = green / 255;
  blue = blue / 255;
  // linearization
  red = red > 0.040_45 ? Math.pow((red + 0.055) / 1.055, 2.4) : red / 12.92;
  green =
    green > 0.040_45 ? Math.pow((green + 0.055) / 1.055, 2.4) : green / 12.92;
  blue = blue > 0.040_45 ? Math.pow((blue + 0.055) / 1.055, 2.4) : blue / 12.92;

  // Matrix multiplication
  let x = red * 0.4124 + green * 0.3576 + blue * 0.1805;
  let y = red * 0.2126 + green * 0.7152 + blue * 0.0722;
  let z = red * 0.0193 + green * 0.1192 + blue * 0.9505;
  // Convert to standard range
  x *= 100;
  y *= 100;
  z *= 100;

  return { x: x, y: y, z: z };
}

export function displayP3ToXyz(
  red: number,
  green: number,
  blue: number
): { x: number; y: number; z: number } {
  // Display-P3 to CIE XYZ
  // convert to range of 0-1
  red = red / 255;
  green = green / 255;
  blue = blue / 255;
  // linearization
  red = red > 0.040_45 ? Math.pow((red + 0.055) / 1.055, 2.4) : red / 12.92;
  green =
    green > 0.040_45 ? Math.pow((green + 0.055) / 1.055, 2.4) : green / 12.92;
  blue = blue > 0.040_45 ? Math.pow((blue + 0.055) / 1.055, 2.4) : blue / 12.92;

  // Matrix multiplication
  let x = red * 0.486_570_9 + green * 0.265_667_7 + blue * 0.198_217_3;
  let y = red * 0.228_974_6 + green * 0.691_738_5 + blue * 0.079_286_9;
  let z = red * 0 + green * 0.045_113_4 + blue * 1.043_944_4;
  // Convert to standard range
  x *= 100;
  y *= 100;
  z *= 100;
  return { x: x, y: y, z: z };
}

